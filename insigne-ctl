#!/bin/bash
# Control script for the Insigne Systeem service.
# Usage: ./insigne-ctl {start|stop|restart|status|logs [journalctl-args]}

# Never run as root / via sudo. This drives the systemd *user* service and
# operates on the service user's checkout + venv. Running it as root talks to
# the wrong systemd instance AND — via `update`'s pip/git — leaves root-owned
# files (e.g. lib/insigne.egg-info) that then break every later update run as
# the service user with "Cannot update time stamp of directory". Run it as the
# account that owns this checkout (e.g. `insignes`), without sudo.
if [ "$(id -u)" -eq 0 ]; then
    echo "ERROR: don't run insigne-ctl as root/sudo." >&2
    if [ -n "$SUDO_USER" ]; then
        echo "       Run it as the service user instead, e.g.:  sudo -u $SUDO_USER $0 ${*:-<command>}" >&2
    else
        echo "       Run it as the account that owns this checkout (the service user), without sudo." >&2
    fi
    exit 1
fi

# Required for systemctl --user to work in non-login shells (e.g. SSH)
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"

SERVICE_NAME="insigne"

case "${1:-}" in
    start)
        systemctl --user start "$SERVICE_NAME"
        systemctl --user status "$SERVICE_NAME" --no-pager
        ;;
    stop)
        systemctl --user stop "$SERVICE_NAME"
        ;;
    restart)
        systemctl --user restart "$SERVICE_NAME"
        systemctl --user status "$SERVICE_NAME" --no-pager
        ;;
    status)
        systemctl --user status "$SERVICE_NAME" --no-pager
        ;;
    logs)
        # Pass any extra arguments directly to journalctl (e.g. -f, -n 100)
        journalctl --user -u "$SERVICE_NAME" "${@:2}"
        ;;
    update)
        SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
        cd "$SCRIPT_DIR"
        git fetch --tags origin
        git checkout -B releases origin/releases
        venv/bin/pip install -q -r requirements.txt
        venv/bin/python api/migrate.py
        systemctl --user restart "$SERVICE_NAME"
        systemctl --user status "$SERVICE_NAME" --no-pager
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|logs|update}"
        echo ""
        echo "  start    Start the service"
        echo "  stop     Stop the service"
        echo "  restart  Restart the service"
        echo "  status   Show service status"
        echo "  logs     Show logs (pass extra flags, e.g. -f or -n 50)"
        echo "  update   Pull latest code and restart"
        exit 1
        ;;
esac
